{
  "name": "siaa-2026-unified",
  "version": "1.0.0",
  "main": "server/server.ts",
  "type": "module",
  "scripts": {
    "dev:server": "npx tsx server/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "start": "NODE_ENV=production npx tsx server/server.ts",
    "engine": "python backend/main.py",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "firebase-admin": "^11.11.1",
    "vite": "^5.0.0",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}

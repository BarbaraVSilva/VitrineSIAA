# ==========================================
# SIAA-2026 — variáveis de ambiente (exemplo)
# Copie para .env e preencha. Nunca commite o .env.
# ==========================================

# --- Segurança (obrigatório em produção / rede local) ---
# Chave partilhada: mesmo valor no .env e no hub /pro (guardado no browser).
SIAA_INTERNAL_API_KEY=gere_uma_chave_longa_aleatoria
# Segredo que a Evolution API envia no header ao chamar POST /webhook/whatsapp
EVOLUTION_API_SECRET=
# Token de verificação dos webhooks Meta (Instagram) — painel Meta Developers
META_VERIFY_TOKEN=
# Opcional: token só para GET /webhook (genérico). Se vazio, usa META_VERIFY_TOKEN.
META_HUB_VERIFY_TOKEN=
# CORS: origens permitidas, separadas por vírgula (ex.: https://seudominio.com). Vazio = * (apenas dev).
SIAA_CORS_ORIGINS=
# Hosts permitidos pelo TrustedHostMiddleware. Vazio = * 
SIAA_ALLOWED_HOSTS=

# --- Telegram (crawler) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE_NUMBER=
TELEGRAM_TARGET_CHANNELS=

# --- Telegram (notificações) ---
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Shopee ---
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=
SHOPEE_AFFILIATE_ID=

# --- Meta / Instagram (publicação e Auto-DM) ---
META_ACCESS_TOKEN=
META_PAGE_ID=
IG_USER_ID=

# --- Evolution API (cliente outbound) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_TOKEN=
EVOLUTION_INSTANCE=SIAA_BOT

# --- IA ---
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- GitHub Pages (vitrine) ---
GITHUB_TOKEN=
GITHUB_REPO=usuario/repositorio

# --- App ---
DB_PATH=db_siaa.sqlite
POST_SCHEDULE_TIMES=12:00,18:00,21:00
TAILSCALE_IP=
